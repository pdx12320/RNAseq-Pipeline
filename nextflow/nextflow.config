// ==============================================================================
// Configuration File: nextflow.config
// Description: Defines default parameters and execution profiles for the pipeline.
// ==============================================================================

params {
    // Input data paths (Automatically pairs _R1 and _R2 files)
    reads       = "$baseDir/data/*_R{1,2}.fastq"
    
    // Reference genome and annotation files
    index       = "/path/to/hisat2_index/genome"
    gtf         = "/path/to/annotation.gtf"
    
    // Output directory
    outdir      = "$baseDir/results"
    
    // Cutadapt trimming parameters
    adapter_r1  = "AGATCGGAAGAGCACACGTCTGAACTCCAGTCA"
    adapter_r2  = "AGATCGGAAGAGCGTCGTGTAGGGAAAGAGTGTA"
    min_len     = 20
    quality     = 20
}

// Execution profiles for different environments
profiles {
    standard {
        process.executor = 'local'
        process.cpus = 8
    }
    
    // Prepared profile for future containerization
    docker {
        docker.enabled = true
        process.container = 'biocontainers/rnaseq:latest' 
    }
}
